function produce_step_4_button_on_click(contemporary_months, historical_months, ROI, mang_img, imagery_scale, indx_list, Chot, Clot, Hhot, Hlot, cont_imagery, hist_imagery, notMassive) {
  return function() {
    ///////////////
    // Section 4 //
    ///////////////
    // The indices variables selected in Section 1 are calculated. Once 
    // calculated, the user will be prompted to export the imagery
    // to their GEE asset folder. 
    
    // Calculation of the spectral indices
    print(ui.Label({value:'Module 1: Section 4',
              style:{fontWeight: 'bold',
                     fontSize: '18px',
                     textAlign: 'center'}
            }));
    print('When the indices have been calculated, four images'+
        '\nalong with their indices will be prepared for export.'+
        '\nThe task tab will turn yellow.'+
        '\n'+
        '\nOnce the task tab turns yellow, click the tab and click'+
        '\non Run for each item that has populated the Tasks tab.'+
        '\nBe sure that the export is directed to your asset folder.');
    
    // Add indices.
    var cont_indxs = indx_mod.add_indices(indx_list, Chot, Clot);
    var hist_indxs = indx_mod.add_indices(indx_list, Hhot, Hlot);
    
    Chot = ee.Image(cont_indxs[0]).float();
    Clot = ee.Image(cont_indxs[1]).float();
    Hhot = ee.Image(hist_indxs[0]).float();
    Hlot = ee.Image(hist_indxs[1]).float();
    
    var export_max_pixels = 1e13;
   
    // Export Imagery with indices as bands
    Export.image.toAsset({
        image: ee.Image(Chot),
        description: 'HOT_Img_contemporary',
        region: ROI,
        scale: imagery_scale,
        maxPixels: export_max_pixels
      });
  
    Export.image.toAsset({
        image: ee.Image(Clot),
        description: 'LOT_Img_contemporary',
        region: ROI,
        scale: imagery_scale,
        maxPixels: export_max_pixels
      });
  
    Export.image.toAsset({
        image: ee.Image(Hhot),
        description: 'HOT_Img_historical',
        region: ROI,
        scale: imagery_scale,
        maxPixels: export_max_pixels
      });
  
    Export.image.toAsset({
        image: ee.Image(Hlot),
        description: 'LOT_Img_historical',
        region: ROI,
        scale: imagery_scale,
        maxPixels: export_max_pixels
      });
  
    ///////////////
    // Section 5 //
    ///////////////
    // Section 5 will create the masks, and ultimately the final mask
    // for the classification(s). The exports will automatically populate  
    // the task tab. Just like the imagery it should be exported to each 
    // user's asset folder.
    
    // section 5 button
    var step_5_button = ui.Button('Section 5: Prepare Image Mask');
    step_5_button.onClick(function() {
      print(ui.Label({value:'Module 1: Section 5',
              style:{fontWeight: 'bold',
                     fontSize: '18px',
                     textAlign: 'center'}
            }));
      print('When the final mask has been prepared the task tab'+
          '\nwill turn yellow, prompting for export. The final mask'+
          '\nand the other intermediary outputs can be viewed in the'+
          '\npanel by clicking on the corresponding button.'+
          '\n'+
          '\nOnce all the of intermediary outputs have begun to export'+
          '\nGEM Module 1 is complete. Proceed to GEM Module 2'+
          '\nafter all outputs have successfully been exported and'+
          '\nadded to the asset GEE asset folder.');
      // Clip the known mangrove extent
      var kn_mang_ext = mang_img.clip(ROI);
    
      // Bring in topo data and create the mask
      var topo_mask = topography.topo_mask_func(topography.dtm(topo, topo_path), kn_mang_ext, mang_topo, elevation, slope);
      
      function waterImagesDescription() {
        print("If your water mask and final mask are incomplete,\n"+
          "review below the number of contemporary and historical\n"+
          "low-tide images available for the water mask.\n\n"+
          "There must be enough images to cover your entire ROI -\n"+
          "if not enough, widen the months and/or years windows\n"+
          "to filter in more imagery."
        );
      }
      
      var waterMask = ee.Image(1);
      if (remove_water === true) {
        print("Counting historical and contemporary water mask images...");
        if (imagery.should_use_sar_water_mask(contemporary_start_year, contemporary_months, historical_start_year, historical_months)) {
          var sar_hist_result = imagery.get_sar_water_mask(ROI, historical_start_year, historical_end_year, historical_months);
          var sar_cont_result = imagery.get_sar_water_mask(ROI, contemporary_start_year, contemporary_end_year, contemporary_months);
          
          var sar_cont_water = sar_cont_result[0];
          var sar_cont_images = sar_cont_result[1];
          
          var sar_hist_water = sar_hist_result[0];
          var sar_hist_images = sar_hist_result[1];
          
          var sar_water_mask = null;
          if (combo_water_mask) {
            sar_water_mask = sar_cont_water.add(sar_hist_water).gte(1);
          } else {
            sar_water_mask = sar_hist_water;
          }
          
          if (notMassive) {
            ee.List([ee.String(sar_hist_images.size()), ee.String(sar_cont_images.size())]).evaluate(function(sarCounts, failure) {
              if (sarCounts) {
                waterImagesDescription();
                print('No. Historical Sentinel-1 SAR Images for Water Mask: ' + sarCounts[0]);
                print('No. Contemporary Sentinel-1 SAR Images for Water Mask: ' + sarCounts[1]);
              }
            });
          }
          
          waterMask = sar_water_mask;
        } else {
          // Use low tide images to create water mask
          var clot_water = cont_imagery.filter(ee.Filter.gte(imagery.mod_water_index, min_avg));
          var clot_water_mosaic = clot_water.qualityMosaic(imagery.inverse_mod_water_index).clip(ROI);
          var hlot_water = hist_imagery.filter(ee.Filter.gte(imagery.mod_water_index, min_avg));
          var hlot_water_mosaic = hlot_water.qualityMosaic(imagery.inverse_mod_water_index).clip(ROI);
          waterMask = imagery.water_mask(hlot_water_mosaic, clot_water_mosaic, combo_water_mask);
          
          if (notMassive) {
            ee.List([ee.String(hlot_water.size()), ee.String(clot_water.size())]).evaluate(function(optCounts, failure) {
              if (optCounts) {
                waterImagesDescription();
                print('No. Historical Low-Tide Images for Water Mask: ' + optCounts[0]);
                print('No. Contemporary Low-Tide Images for Water Mask: ' + optCounts[1]);
              }
            });
          }
        }
      }
      
      // Combine the topo and water masks
      var final_mask = waterMask.multiply(topo_mask).eq(1);
      
      // Add buttons to view the mask outputs
      var topo_mask_butt = ui.Button('View Topo Mask?');
          topo_mask_butt.onClick(function(){
            Map.addLayer(ee.Image(topo_mask.clip(ROI)), {}, 'Topographic Mask');});
      var water_mask_butt = ui.Button('View water Mask?');
          water_mask_butt.onClick(function(){
            Map.addLayer(ee.Image(waterMask.clip(ROI)), {}, 'Water Mask');});
      var final_mask_butt = ui.Button('View Final Mask?');
          final_mask_butt.onClick(function(){
            Map.addLayer(ee.Image(final_mask.clip(ROI)), {}, 'Final Mask');});
      
      // Export final mask
      Export.image.toAsset({
          image: final_mask,
          description: 'Final_mask',
          region: ROI,
          scale: imagery_scale,
          maxPixels: export_max_pixels
        });
        
      // Prepare final ROI for export
      var ROI_out = ee.FeatureCollection(ee.Feature(ROI, {name: 'ROI'}));
      // Export final ROI
      Export.table.toAsset({
        collection: ROI_out,
        description: "ROI",
        assetId: 'ROI'
        });
          
      // Create Panel
      var mask_panel = ui.Panel({
        layout: ui.Panel.Layout.flow('vertical'),
        style: {width: '300px'}
        });
        
      // Add buttons to the panel
      mask_panel.add(topo_mask_butt);
      mask_panel.add(water_mask_butt);
      mask_panel.add(final_mask_butt);
      
      // Add the panel to the map
      ui.root.add(mask_panel);
    });
    print(step_5_button);
  };
}


