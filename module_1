     The user defined topographic thresholds: (discarded if mang_topo = true)
     
     Enter:
          var elevation = 39; (meters, meters above sea level)
          var slope = 16; (%, percent change in slope)
*/

var mang_topo = true;
var elevation = 39;
var slope = 16;

