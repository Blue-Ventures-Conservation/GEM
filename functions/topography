exports.topo_mask = function(topo, topo_path, mangroves, mang_topo, elevation, elevationPercentile, slope) {
  if (topo === true) {
    return fabdemTopoMask(mangroves, mang_topo, elevation, elevationPercentile, slope);
  } else {
    return handleTopo(ee.Image(topo_path).rename('elev'), mangroves, mang_topo, elevation, elevationPercentile, slope, "User Provided Elevation Model");
  }
};

function handleTopo(img, mangroves, mang_topo, elevation, elevationPercentile, slope, label) {
  var model = ee.Image(img);
  
  if(slopeEnabled === true) {
    model = model.addBands(ee.Terrain.slope(model.select('elev')).double().rename('slope'));
  }
  
  //extract slope and elevation max from known mangrove extent
  var mang_elv = model.select('elev').updateMask(mangroves)
    .reduceRegion({
      reducer: ee.Reducer.percentile({percentiles: [elevationPercentile]}),
      geometry: mangroves.geometry(),
      scale: 30,
      maxPixels: 1e12,
      bestEffort: true
  });

  var mang_slope = model.select('slope').updateMask(mangroves)
   .reduceRegion({
      reducer: ee.Reducer.percentile({percentiles: [elevationPercentile]}),
      geometry: mangroves.geometry(),
      scale: 30,
      maxPixels: 1e12,
      bestEffort: true
  });
  
  var el_img = ee.Image.constant(elevation);
  var slp_img = ee.Image.constant(slope);
  
  if (mang_topo === true) {
    var el_val = mang_elv.get('elev');
    var slp_val = mang_slope.get('slope');
    el_img = ee.Image.constant(el_val);
    slp_img = ee.Image.constant(slp_val);
    
    var fetchStr = "\n";
    var toFetch = ee.List([el_val]);
    if (slopeEnabled) {
      fetchStr = " and\nslope ";
      toFetch = toFetch.add(slp_val);
    }
    
    print("Fetching " + elevationPercentile + "th percentile elevation" + fetchStr + "for known mangrove extent...");
    toFetch.evaluate(function(vals, failure) {
      if (vals) {
        print(label + " " + elevationPercentile + "th percentile known mangrove elevation: " + vals[0]);
        if (slopeEnabled) {
          print(label + " " + elevationPercentile + "th percentile known mangrove slope: " + vals[1]);
        }
      } else {
        print("Could not calculate " + elevationPercentile + " percentile elevation" + fetchStr + failure);
      }
    });
  }
  
  var topo_mask = model.select('elev').lte(el_img);
  if (slopeEnabled) {
    topo_mask = topo_mask.and(model.select('slope').lte(slp_img));
  }
  
  return topo_mask.double();
}



