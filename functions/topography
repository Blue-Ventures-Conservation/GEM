var slopeEnabled = false;

// this is the current elevation model in use
function fabdemTopoMask(mangroves, mang_topo, elevation, elevationPercentile, slope) {
  var fabdem = ee.ImageCollection("projects/sat-io/open-datasets/FABDEM");
  var dem = fabdem.mosaic().setDefaultProjection('EPSG:3857', null, 30).rename('elev');
  return handleTopo(dem, mangroves, mang_topo, elevation, elevationPercentile, slope, "FABDEM");
}

