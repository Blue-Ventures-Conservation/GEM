/*

This is the spectral band/index correlation module, which is part 
of the BVC GEM v1.2 library. It is used to determine the correlation
between potential spectral classification inputs.

Last Updated: 18 April 2026
*/

exports.pearson_cor_mat = function(img, bands, geom){
  var mat = pearson_correlation(img, bands, geom);
  print(mat);
};

function pearson_correlation(img, bands, geom) {
  var bcount = bands.size();
  var p1 = bcount.divide(3).round();
  var p2 = p1.add(p1);
  var s1 = bands.slice(0, p1);
  var s2 = bands.slice(p1, p2);
  var s3 = bands.slice(p2, bcount.add(1));
  var matrix = correlation_rows(s1, bands, img, geom).cat(correlation_rows(s2, bands, img, geom)).cat(correlation_rows(s3, bands, img, geom));
  return matrix;
}

function correlation_rows(subset, bands, img, geom) {
  return subset.map(function(band) {
    return correlation_row(band, bands, img, geom);
  });
}

function correlation_row(band, bands, img, geom) {
  var fifth = bands.size().divide(5).int().add(1);
  
  var base = img.select([band], ['base']);
  var s1 = correlation_partial_row(base, bands.slice(0, fifth), img, geom);
  var s2 = correlation_partial_row(base, bands.slice(fifth, fifth.multiply(2)), img, geom);
  var s3 = correlation_partial_row(base, bands.slice(fifth.multiply(2), fifth.multiply(3)), img, geom);
  var s4 = correlation_partial_row(base, bands.slice(fifth.multiply(3), fifth.multiply(4)), img, geom);
  var s5 = correlation_partial_row(base, bands.slice(fifth.multiply(4), fifth.multiply(5)), img, geom);
  
  return ee.List([s1, s2, s3, s4, s5]).flatten().map(function(i) {
    return ee.String(i);
  }).join(' ');
}

function correlation_partial_row(base, bands_sublist, img, geom) {
  return bands_sublist.map(function(b) {
    return correlation_cell(img.select([b]).addBands(base), geom);
  });
}

function correlation_cell(img, geom) {
  return ee.Number(img.reduceRegion({
    reducer: ee.Reducer.pearsonsCorrelation(),
    maxPixels: 1e13,
    geometry: geom,
    scale: 100,
    tileScale: 1,
  }).get('correlation')).multiply(100000).round().divide(100000);
}
